	$(MAKE) $(MAKESILENT) -f CMakeFiles/splitcommander.dir/build.make CMakeFiles/splitcommander.dir/src/themedialog.cpp.s
.PHONY : src/themedialog.cpp.s

src/thememanager.o: src/thememanager.cpp.o
